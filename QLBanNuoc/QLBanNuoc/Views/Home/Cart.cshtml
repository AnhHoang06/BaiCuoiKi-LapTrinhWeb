@{
    ViewData["Title"] = "Giỏ Hàng – Water Shop";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ Hàng – LATShop</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Pacifico&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --orange: #F97316; --orange-dark: #EA580C; --orange-light: #FED7AA;
            --cyan: #06B6D4; --cyan-dark: #0891B2;
            --green: #16A34A; --green-dark: #15803D;
            --white: #ffffff; --gray-50: #F8FAFC; --gray-100: #F1F5F9;
            --gray-200: #E2E8F0; --gray-700: #374151; --gray-900: #111827;
            --shadow: 0 4px 20px rgba(0,0,0,0.10); --shadow-lg: 0 8px 32px rgba(0,0,0,0.14);
            --radius: 14px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Nunito',sans-serif; background:var(--gray-50); color:var(--gray-900); }

        .navbar {
            background:var(--orange); padding:0 40px;
            display:flex; align-items:center; justify-content:space-between;
            height:64px; position:sticky; top:0; z-index:1000;
            box-shadow:0 2px 12px rgba(249,115,22,0.3);
        }
        .brand-icon { width:42px;height:42px;background:white;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px; }
        .brand-name { font-family:'Pacifico',cursive;color:white;font-size:20px;margin-left:10px; }
        .navbar-brand { display:flex;align-items:center;text-decoration:none; }
        .nav-back { color:white;text-decoration:none;font-weight:700;font-size:15px;display:flex;align-items:center;gap:6px;opacity:0.92; }
        .nav-back:hover { opacity:1;color:white; }

        .container { max-width:1200px;margin:0 auto;padding:0 24px; }
        .page-title { font-size:26px;font-weight:900;padding:32px 0 24px;display:flex;align-items:center;gap:10px; }

        .cart-layout { display:grid;grid-template-columns:1fr 420px;gap:28px;padding-bottom:48px; }

        /* Cart items */
        .cart-items { background:white;border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden; }
        .cart-header { padding:20px 24px;border-bottom:1px solid var(--gray-200);font-weight:800;font-size:16px;display:flex;align-items:center;gap:8px; }
        .cart-empty { padding:60px;text-align:center;color:#94A3B8; }
        .cart-empty i { font-size:48px;margin-bottom:16px;display:block; }
        .cart-empty p { font-size:16px;margin-bottom:20px; }

        .cart-item { display:flex;align-items:center;gap:16px;padding:16px 24px;border-bottom:1px solid var(--gray-100); transition:background 0.2s; }
        .cart-item:hover { background:var(--gray-50); }
        .cart-item:last-child { border-bottom:none; }

        .item-img {
            width:70px;height:70px;border-radius:10px;overflow:hidden;flex-shrink:0;
            background:linear-gradient(135deg,var(--orange),#FBBF24);
            display:flex;align-items:center;justify-content:center;font-size:30px;
        }
        .item-img img { width:100%;height:100%;object-fit:cover; }

        .item-info { flex:1; }
        .item-name { font-weight:800;font-size:15px;margin-bottom:4px; }
        .item-price { color:var(--orange-dark);font-weight:700;font-size:14px; }

        .item-qty { display:flex;align-items:center;gap:0;border:2px solid var(--gray-200);border-radius:8px;overflow:hidden; }
        .iq-btn { width:32px;height:32px;background:var(--gray-100);border:none;font-size:16px;font-weight:700;cursor:pointer;transition:background 0.2s;display:flex;align-items:center;justify-content:center; }
        .iq-btn:hover { background:var(--orange-light); }
        .iq-val { width:40px;text-align:center;font-weight:800;font-size:15px;padding:0; }

        .item-total { font-weight:900;font-size:16px;color:var(--gray-900);min-width:90px;text-align:right; }
        .item-delete { background:none;border:none;color:#EF4444;font-size:18px;cursor:pointer;padding:6px;border-radius:8px;transition:background 0.2s; }
        .item-delete:hover { background:#FEE2E2; }

        .cart-total-bar { padding:16px 24px;background:var(--gray-50);border-top:2px solid var(--gray-200);display:flex;justify-content:space-between;align-items:center; }
        .cart-total-bar span { font-weight:700;font-size:15px; }
        .cart-total-bar strong { font-size:20px;color:var(--orange-dark); }

        /* Order form */
        .order-form { background:white;border-radius:var(--radius);box-shadow:var(--shadow);padding:28px;height:fit-content; }
        .form-title { font-size:18px;font-weight:900;margin-bottom:20px;display:flex;align-items:center;gap:8px; }

        .form-group { margin-bottom:16px; }
        .form-group label { display:block;font-weight:700;font-size:13px;color:var(--gray-700);margin-bottom:6px; }
        .form-group input, .form-group select, .form-group textarea {
            width:100%;border:2px solid var(--gray-200);border-radius:10px;
            padding:11px 14px;font-family:'Nunito',sans-serif;font-size:14px;
            outline:none;transition:border 0.2s;background:white;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color:var(--orange); }
        .form-group textarea { resize:vertical;min-height:80px; }

        .order-type-group { display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px; }
        .ot-btn { padding:10px 6px;border:2px solid var(--gray-200);background:white;border-radius:10px;font-family:'Nunito',sans-serif;font-weight:700;font-size:13px;cursor:pointer;text-align:center;transition:all 0.2s; }
        .ot-btn.active { border-color:var(--orange);background:var(--orange-light);color:var(--orange-dark); }

        .submit-btn {
            width:100%;background:var(--orange);color:white;border:none;border-radius:12px;
            padding:14px;font-family:'Nunito',sans-serif;font-weight:800;font-size:16px;
            cursor:pointer;transition:background 0.2s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px;
        }
        .submit-btn:hover { background:var(--orange-dark); }
        .submit-btn:disabled { background:#94A3B8;cursor:not-allowed; }

        .order-summary { background:var(--gray-50);border-radius:10px;padding:16px;margin-top:16px; }
        .os-row { display:flex;justify-content:space-between;font-size:14px;padding:4px 0; }
        .os-row.total { border-top:2px solid var(--gray-200);margin-top:8px;padding-top:10px;font-weight:900;font-size:16px; }

        /* Success modal */
        .success-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:5000;align-items:center;justify-content:center;backdrop-filter:blur(4px); }
        .success-overlay.show { display:flex; }
        .success-box { background:white;border-radius:20px;padding:48px 40px;text-align:center;max-width:400px;animation:slideUp 0.3s ease; }
        @@keyframes slideUp { from{transform:translateY(30px);opacity:0} to{transform:translateY(0);opacity:1} }
        .success-icon { font-size:64px;margin-bottom:16px; }
        .success-box h2 { font-size:22px;font-weight:900;margin-bottom:8px; }
        .success-box p { color:#64748B;font-size:14px;margin-bottom:24px; }
        .success-btn { background:var(--orange);color:white;border:none;border-radius:10px;padding:12px 28px;font-family:'Nunito',sans-serif;font-weight:700;font-size:15px;cursor:pointer;transition:background 0.2s; }
        .success-btn:hover { background:var(--orange-dark); }

        @@media(max - width:900px) {
            .cart-layout { grid-template-columns:1fr; }
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            background: white;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden; 
        }

            .brand-icon img {
                width: 70%; 
                height: 70%;
                object-fit: contain;
            }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="navbar-brand">
            <div class="brand-icon">
                <img src="~/images/logo-lat2.png" alt="Logo" />
            </div>
            <span class="brand-name">LATShop</span>
        </a>
        <a href="/" class="nav-back"><i class="fas fa-arrow-left"></i> Tiếp tục mua</a>
    </nav>

    <div class="container">
        <div class="page-title"><i class="fas fa-shopping-cart" style="color:var(--orange);"></i> Giỏ Hàng</div>

        <div class="cart-layout">
            <!-- LEFT: Cart items -->
            <div class="cart-items">
                <div class="cart-header"><i class="fas fa-list" style="color:var(--orange);"></i> Sản phẩm đã chọn</div>
                <div id="cartItemsList"></div>
                <div class="cart-total-bar">
                    <span>Tổng cộng</span>
                    <strong id="cartTotalDisplay">đ 0</strong>
                </div>
            </div>

            <!-- RIGHT: Order form -->
            <div class="order-form">
                <div class="form-title"><i class="fas fa-clipboard-list" style="color:var(--orange);"></i> Thông tin đặt hàng</div>

                <div class="form-group">
                    <label>Họ và tên *</label>
                    <input type="text" id="fName" placeholder="Nguyễn Văn A" />
                </div>
                <div class="form-group">
                    <label>Số điện thoại *</label>
                    <input type="tel" id="fPhone" placeholder="0123 456 789" />
                </div>

                <div class="form-group">
                    <label>Hình thức *</label>
                    <div class="order-type-group">
                        <button class="ot-btn active" onclick="selectType(this,'TaiQuan')">🪑 Tại quán</button>
                        <button class="ot-btn" onclick="selectType(this,'MangDi')">🛍️ Mang đi</button>
                        <button class="ot-btn" onclick="selectType(this,'GiaoHang')">🛵 Giao hàng</button>
                    </div>
                </div>

                <div id="tableSection" class="form-group">
                    <label>Số bàn *</label>
                    <input type="number" id="fTable" placeholder="Nhập số bàn" min="1" />
                </div>

                <div id="addressSection" class="form-group" style="display:none;">
                    <label>Địa chỉ giao hàng *</label>
                    <input type="text" id="fAddress" placeholder="Số nhà, đường, phường..." />
                </div>

                <div class="form-group">
                    <label>Ghi chú</label>
                    <textarea id="fNote" placeholder="Ít đường, nhiều đá..."></textarea>
                </div>

                <!-- Order summary -->
                <div class="order-summary">
                    <div class="os-row"><span>Số lượng sản phẩm</span><span id="osSumQty">0</span></div>
                    <div class="os-row"><span>Tạm tính</span><span id="osSumPrice">đ 0</span></div>
                    <div class="os-row total"><span>Tổng thanh toán</span><span id="osSumTotal">đ 0</span></div>
                </div>

                <button class="submit-btn" id="submitBtn" onclick="submitOrder()">
                    <i class="fas fa-credit-card"></i> Đặt hàng ngay
                </button>
            </div>
        </div>
    </div>

    <!-- Success modal -->
    <div class="success-overlay" id="successOverlay">
        <div class="success-box">
            <div class="success-icon">🎉</div>
            <h2>Đặt hàng thành công!</h2>
            <p>Cảm ơn bạn đã đặt hàng. Chúng tôi sẽ xử lý đơn hàng của bạn sớm nhất!</p>
            <button class="success-btn" onclick="finishOrder()">Về trang chủ</button>
        </div>
    </div>

    <script>
        let cart = JSON.parse(localStorage.getItem('wsCart') || '[]');
        let selectedType = 'TaiQuan';

        function renderCart() {
            const list = document.getElementById('cartItemsList');
            if (cart.length === 0) {
                list.innerHTML = `
                    <div class="cart-empty">
                        <i class="fas fa-shopping-cart"></i>
                        <p>Giỏ hàng của bạn đang trống</p>
                        <a href="/" style="color:var(--orange);font-weight:700;">Mua ngay →</a>
                    </div>`;
                document.getElementById('submitBtn').disabled = true;
            } else {
                document.getElementById('submitBtn').disabled = false;
                list.innerHTML = cart.map((item, idx) => `
                    <div class="cart-item">
                        <div class="item-img">
                            ${item.img ? `<img src="${item.img}" alt="${item.name}" />` : '💧'}
                        </div>
                        <div class="item-info">
                            <div class="item-name">${item.name}</div>
                            <div class="item-price">đ ${item.price.toLocaleString('vi-VN')}</div>
                        </div>
                        <div class="item-qty">
                            <button class="iq-btn" onclick="updateQty(${idx},-1)">−</button>
                            <span class="iq-val">${item.qty}</span>
                            <button class="iq-btn" onclick="updateQty(${idx},1)">+</button>
                        </div>
                        <div class="item-total">đ ${(item.price * item.qty).toLocaleString('vi-VN')}</div>
                        <button class="item-delete" onclick="removeItem(${idx})"><i class="fas fa-trash"></i></button>
                    </div>
                `).join('');
            }

            const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
            const qty = cart.reduce((s, i) => s + i.qty, 0);
            document.getElementById('cartTotalDisplay').textContent = 'đ ' + total.toLocaleString('vi-VN');
            document.getElementById('osSumQty').textContent = qty;
            document.getElementById('osSumPrice').textContent = 'đ ' + total.toLocaleString('vi-VN');
            document.getElementById('osSumTotal').textContent = 'đ ' + total.toLocaleString('vi-VN');
        }

        function updateQty(idx, delta) {
            cart[idx].qty = Math.max(1, cart[idx].qty + delta);
            localStorage.setItem('wsCart', JSON.stringify(cart));
            renderCart();
        }

        function removeItem(idx) {
            cart.splice(idx, 1);
            localStorage.setItem('wsCart', JSON.stringify(cart));
            renderCart();
        }

        function selectType(btn, type) {
            selectedType = type;
            document.querySelectorAll('.ot-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('tableSection').style.display = type === 'TaiQuan' ? 'block' : 'none';
            document.getElementById('addressSection').style.display = type === 'GiaoHang' ? 'block' : 'none';
        }

        function submitOrder() {
            const name = document.getElementById('fName').value.trim();
            const phone = document.getElementById('fPhone').value.trim();
            if (!name) { alert('Vui lòng nhập họ tên!'); return; }
            if (!phone) { alert('Vui lòng nhập số điện thoại!'); return; }
            if (cart.length === 0) { alert('Giỏ hàng đang trống!'); return; }
            if (selectedType === 'TaiQuan' && !document.getElementById('fTable').value) {
                alert('Vui lòng nhập số bàn!'); return;
            }
            if (selectedType === 'GiaoHang' && !document.getElementById('fAddress').value.trim()) {
                alert('Vui lòng nhập địa chỉ giao hàng!'); return;
            }

            const orderData = {
                customerName: name,
                phone: phone,
                orderType: selectedType,
                tableNumber: selectedType === 'TaiQuan' ? document.getElementById('fTable').value : null,
                deliveryAddress: selectedType === 'GiaoHang' ? document.getElementById('fAddress').value.trim() : null,
                note: document.getElementById('fNote').value.trim(),
                items: cart.map(i => ({ drinkId: i.id, qty: i.qty, price: i.price })),
                totalPrice: cart.reduce((s, i) => s + i.price * i.qty, 0)
            };

            fetch('/Home/PlaceOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('successOverlay').classList.add('show');
                } else {
                    alert('Có lỗi: ' + (data.message || 'Vui lòng thử lại.'));
                }
            })
            .catch(() => {
                // Fallback nếu chưa có API
                document.getElementById('successOverlay').classList.add('show');
            });
        }

        function finishOrder() {
            cart = [];
            localStorage.setItem('wsCart', '[]');
            window.location.href = '/';
        }

        renderCart();
    </script>
</body>
</html>
