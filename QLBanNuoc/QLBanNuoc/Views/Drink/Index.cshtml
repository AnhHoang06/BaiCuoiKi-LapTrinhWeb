@model IEnumerable<dynamic>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý đồ uống";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-lat-orange">QUẢN LÝ ĐỒ UỐNG</h3>
    <a href="/Drink/Create" class="btn bg-lat-orange text-white fw-bold px-4 rounded-pill shadow-sm">
        <i class="bi bi-plus-circle-fill me-2"></i> THÊM MÓN MỚI
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-muted">MÃ</th>
                    <th class="py-3 text-muted">TÊN MÓN</th>
                    <th class="py-3 text-muted">DANH MỤC</th>
                    <th class="py-3 text-muted">GIÁ BÁN</th>
                    <th class="py-3 text-muted">TRẠNG THÁI</th>
                    <th class="text-center py-3 text-muted">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var drink in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">#@drink.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                    <i class="bi bi-cup-hot text-lat-orange fs-4"></i>
                                </div>
                                <span class="fw-bold text-dark">@drink.Name</span>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@drink.Category</span></td>
                        <td class="fw-bold text-lat-orange">@string.Format("{0:N0}", drink.Price) đ</td>
                        <td>
                            @if (drink.Status == "Còn hàng")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Còn hàng</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">Hết hàng</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning me-1 border-0">
                                <i class="bi bi-pencil-square fs-5"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger border-0">
                                <i class="bi bi-trash3-fill fs-5"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>