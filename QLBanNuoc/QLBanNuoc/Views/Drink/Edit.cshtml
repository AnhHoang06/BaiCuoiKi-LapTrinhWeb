@model QLBanNuoc.Models.Drink
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh Sửa Đồ Uống";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-lat-orange">CHỈNH SỬA MÓN</h3>
    <a href="/Drink/Index" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left me-2"></i> QUAY LẠI
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-secondary">Tên món</label>
                    <input asp-for="Name" class="form-control" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-secondary">Danh mục</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required></select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-secondary">Giá bán (VNĐ)</label>
                    <input asp-for="Price" type="number" class="form-control" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold text-secondary">Thay đổi hình ảnh</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*">

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mt-2">
                            <small class="text-muted d-block mb-1">Ảnh hiện tại:</small>
                            <img src="@Model.ImageUrl" class="rounded-3 shadow-sm" style="height: 80px; object-fit: cover;">
                        </div>
                    }
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-4 form-check form-switch">
                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" id="statusSwitch">
                <label class="form-check-label fw-bold text-secondary ms-2" for="statusSwitch">Đang kinh doanh</label>
            </div>

            <hr class="text-muted my-4">

            <div class="text-end">
                <button type="submit" class="btn bg-lat-orange text-white fw-bold px-5 rounded-pill shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> CẬP NHẬT
                </button>
            </div>
        </form>
    </div>
</div>