@model QLBanNuoc.Models.Order
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-lat-orange">CHI TIẾT ĐƠN HÀNG #@Model.Id</h3>
    <a href="/Order/Manage" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left me-2"></i> QUAY LẠI
    </a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h6 class="fw-bold text-secondary mb-0"><i class="bi bi-person-lines-fill me-2"></i>THÔNG TIN CHUNG</h6>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Khách hàng:</strong> @Model.CustomerName</p>
                <p class="mb-2"><strong>Điện thoại:</strong> @Model.Phone</p>
                <p class="mb-2"><strong>Thời gian đặt:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                <hr class="text-muted">
                <p class="mb-2">
                    <strong>Loại đơn:</strong>
                    @if (Model.OrderType == "TaiQuan")
                    {
                        <span>Tại quán (Bàn @Model.CafeTable?.TableNumber)</span>
                    }
                    else if (Model.OrderType == "MangDi")
                    {
                        <span>Mang đi</span>
                    }
                    else
                    {
                        <span>Giao hàng</span>
                    }
                </p>
                @if (Model.OrderType == "GiaoHang")
                {
                    <p class="mb-2"><strong>Người nhận:</strong> @Model.ReceiverName</p>
                    <p class="mb-2"><strong>Địa chỉ:</strong> @Model.DeliveryAddress</p>
                }
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="alert alert-warning py-2 mt-3 mb-0">
                        <strong>Ghi chú:</strong> @Model.Note
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted">MÓN NƯỚC</th>
                            <th class="py-3 text-muted text-center">SỐ LƯỢNG</th>
                            <th class="py-3 text-muted text-end pe-4">THÀNH TIỀN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark">@item.Drink?.Name</span>
                                    <br />
                                    <small class="text-muted">@string.Format("{0:N0}", item.Price) đ / ly</small>
                                </td>
                                <td class="text-center fw-bold">x @item.Quantity</td>
                                <td class="text-end pe-4 fw-bold text-lat-orange">
                                    @string.Format("{0:N0}", item.Quantity * item.Price) đ
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-light">
                        <tr>
                            <td colspan="2" class="text-end py-3 fw-bold">TỔNG CỘNG:</td>
                            <td class="text-end pe-4 py-3 fw-bold text-danger fs-5">
                                @string.Format("{0:N0}", Model.TotalPrice) đ
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>