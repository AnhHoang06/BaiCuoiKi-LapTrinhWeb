@model IEnumerable<QLBanNuoc.Models.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý danh mục";
}

@* Header: phong cách LAT *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-lat-orange">QUẢN LÝ DANH MỤC</h3>
    <button class="btn bg-lat-orange text-white fw-bold px-4 rounded-pill shadow-sm">
        <i class="bi bi-plus-circle-fill me-2"></i> THÊM DANH MỤC MỚI
    </button>
</div>


<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-muted" style="width: 15%;">MÃ</th>
                    <th class="py-3 text-muted" style="width: 60%;">TÊN DANH MỤC</th>
                    <th class="text-center py-3 text-muted" style="width: 25%;">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="bi bi-tags text-lat-orange fs-5"></i>
                                </div>
                                <span class="fw-bold text-dark text-uppercase">@item.Name</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning me-2 border-0">
                                <i class="bi bi-pencil-square fs-5"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger border-0">
                                <i class="bi bi-trash3-fill fs-5"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<div class="mt-3 text-muted small">
    <i class="bi bi-info-circle me-1"></i> Tổng cộng có <strong>@Model.Count()</strong> danh mục đang hoạt động trên hệ thống.
</div>