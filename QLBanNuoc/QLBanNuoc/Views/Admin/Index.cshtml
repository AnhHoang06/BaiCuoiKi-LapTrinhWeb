@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tổng quan hệ thống";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-lat-orange">TỔNG QUAN HỆ THỐNG</h3>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm rounded-4 bg-primary text-white h-100">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-white bg-opacity-25 rounded-3 p-3 me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-receipt-cutoff fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 text-uppercase fw-bold opacity-75 small">Tổng Đơn Hàng</p>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalOrders</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm rounded-4 bg-success text-white h-100">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-white bg-opacity-25 rounded-3 p-3 me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-cash-stack fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 text-uppercase fw-bold opacity-75 small">Doanh Thu Thực Tế</p>
                    <h2 class="mb-0 fw-bold">@string.Format("{0:N0}", ViewBag.TotalRevenue) đ</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm rounded-4 text-white h-100" style="background-color: var(--lat-orange);">
            <div class="card-body d-flex align-items-center p-4">
                <div class="bg-white bg-opacity-25 rounded-3 p-3 me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-cup-straw fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 text-uppercase fw-bold opacity-75 small">Món Đang Bán</p>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalDrinks</h2>
                </div>
            </div>
        </div>
    </div>
</div>
