@{
    // LỆNH QUAN TRỌNG: Tắt Layout chung, trang này sẽ đứng độc lập 100%
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - LAT Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        :root {
            --lat-orange: #ff6b00; /* Màu cam LAT */
            --lat-light-orange: #fff5ed; /* Màu nền nhạt */
        }

        body {
            /* Lệnh giúp toàn bộ trang web cao bằng màn hình và căn giữa Form */
            background-color: var(--lat-light-orange);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(255, 107, 0, 0.15); /* Đổ bóng màu cam nhạt */
            width: 100%;
            max-width: 420px;
            padding: 2.5rem 2rem;
            text-align: center;
        }

        .btn-lat {
            background-color: var(--lat-orange);
            color: white;
            font-weight: 700;
            padding: 12px;
            border-radius: 8px;
            letter-spacing: 1px;
            transition: 0.3s;
        }

            .btn-lat:hover {
                background-color: #e66000;
                color: white;
                transform: translateY(-2px);
            }

        /* Đổi màu viền ô nhập liệu khi click vào thành màu cam */
        .form-control:focus {
            border-color: var(--lat-orange);
            box-shadow: 0 0 0 0.25rem rgba(255, 107, 0, 0.25);
        }
    </style>
</head>
<body>

    <div class="login-card">
        <img src="~/images/logo-lat.png" alt="LAT Logo" style="height: 70px; margin-bottom: 20px;">

        <h5 class="mb-4 fw-bold text-dark">ĐĂNG NHẬP HỆ THỐNG</h5>

        <form action="/Admin/Login" method="post">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger p-2 small">@ViewBag.Error</div>
            }

            <div class="mb-3 text-start">
                <label class="form-label text-muted fw-bold small">Tài khoản</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-person text-muted"></i></span>
                    <input type="text" name="username" class="form-control" placeholder="admin" required>
                </div>
            </div>

            <div class="mb-4 text-start">
                <label class="form-label text-muted fw-bold small">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-lock text-muted"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="btn btn-lat w-100 border-0">ĐĂNG NHẬP</button>
        </form>

        <div class="mt-4">
            <small class="text-muted">© 2026 LAT System</small>
        </div>
    </div>

</body>
</html>